# UltraDev Configuration
# Copy to .env and fill in your values

# GitHub username that issues get assigned to
ULTRADEV_GITHUB_USERNAME=your-github-username

# Polling interval in milliseconds (default: 120000 = 2 minutes)
ULTRADEV_POLL_INTERVAL_MS=120000

# Discord bot (optional)
ULTRADEV_DISCORD_ENABLED=true
ULTRADEV_DISCORD_TOKEN=
ULTRADEV_DISCORD_OWNER_USER_ID=
ULTRADEV_DISCORD_NOTIFY_CHANNEL_ID=
# Comma-separated channelId:authorId pairs that can trigger !work in channels
ULTRADEV_DISCORD_TRIGGER_WHITELIST=

# Error Watcher (reads Discord channels for production errors, creates GitHub issues)
ULTRADEV_ERROR_WATCHER_ENABLED=true
ULTRADEV_ERROR_WATCHER_REPO=owner/repo
ULTRADEV_ERROR_WATCHER_LABELS=production,bug,auto-triaged
# ULTRADEV_ERROR_WATCHER_INTERVAL_MS=43200000  # 12h default

# Paths (defaults to ~/ultradev/repos and ~/ultradev/logs)
ULTRADEV_REPOS_DIR=
ULTRADEV_LOGS_DIR=

# Claude CLI command and flags
ULTRADEV_CLAUDE_COMMAND=claude
ULTRADEV_CLAUDE_FLAGS=--dangerously-skip-permissions

# Server port (default: 4800)
PORT=4800
